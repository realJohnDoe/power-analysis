# Tibber API Configuration
# Copy this file to .env and fill in your values

# Required: Your Tibber access token from https://developer.tibber.com/
TIBBER_ACCESS_TOKEN=your-token-here

# Optional: Custom output CSV path inside container
# Default is /data/tibber_pulse.csv which maps to monthly files like /data/tibber_pulse_2024-01.csv
TIBBER_OUTPUT_CSV_PATH=/data/tibber_pulse.csv
